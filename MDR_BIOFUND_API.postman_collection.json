                  "    pm.collectionVariables.set('occurrence_id', res.occurrence_id);",
                  "    console.log('occurrence_id guardado:', res.occurrence_id);",
                  "}",
                  "if (res.tracking_code) {",
                  "    pm.collectionVariables.set('tracking_code', res.tracking_code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
