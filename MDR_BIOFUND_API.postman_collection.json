              "raw": "{\n  \"project_id\": 2,\n  \"category_id\": 4,\n  \"subcategory_id\": null,\n  \"occurrence_type_id\": 6,\n  \"province_id\": 4,\n  \"district_id\": null,\n  \"location_detail\": \"Aldeia Mucarara\",\n  \"subject\": \"Caso de violência doméstica reportado na reunião\",\n  \"description\": \"Durante a reunião comunitária realizada na aldeia Mucarara, foi reportado um caso de violência doméstica que requer acompanhamento imediato pelas autoridades competentes.\",\n  \"occurrence_date\": \"2026-05-07\",\n  \"submission_channel\": \"community_meeting\",\n  \"alert_type\": \"gbv\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/occurrences",
