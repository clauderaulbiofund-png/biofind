              "path": ["public", "occurrences"]
            },
            "description": "Formulário público - não requer login.\nNÃO tem submission_channel nem alert_type (campos exclusivos internos).\nO tracking_code é guardado automaticamente em {{tracking_code}}."
          }
        },

        {
          "name": "Criar ocorrência externa COM imagem",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "complainant_name", "value": "João Machava", "type": "text" },
                { "key": "complainant_email", "value": "joao.machava@email.com", "type": "text" },
                { "key": "complainant_phone", "value": "+258 82 987 6543", "type": "text" },
                { "key": "project_id", "value": "2", "type": "text" },
                { "key": "category_id", "value": "4", "type": "text" },
                { "key": "occurrence_type_id", "value": "6", "type": "text" },
                { "key": "province_id", "value": "3", "type": "text" },
                { "key": "subject", "value": "Situação de violência reportada", "type": "text" },
                { "key": "description", "value": "Descrição detalhada da situação ocorrida na comunidade, com testemunhas presentes.", "type": "text" },
                { "key": "occurrence_date", "value": "2026-05-05", "type": "text" },
                { "key": "attachments[]", "type": "file", "src": "", "description": "Selecionar imagem JPG, PNG ou PDF (máx 10MB)" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/public/occurrences",
              "host": ["{{base_url}}"],
              "path": ["public", "occurrences"]
