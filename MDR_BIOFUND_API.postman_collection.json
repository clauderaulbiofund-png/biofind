                  "    pm.collectionVariables.set('tracking_code', res.tracking_code);",
                  "    console.log('Tracking code guardado:', res.tracking_code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"complainant_name\": \"Maria da Silva\",\n  \"complainant_email\": \"maria.silva@email.com\",\n  \"complainant_phone\": \"+258 84 123 4567\",\n  \"project_id\": 1,\n  \"category_id\": 1,\n  \"subcategory_id\": null,\n  \"occurrence_type_id\": 1,\n  \"province_id\": 1,\n  \"district_id\": null,\n  \"location_detail\": \"Bairro Central, perto do mercado\",\n  \"subject\": \"Poluição do rio Incomáti\",\n  \"description\": \"Verificou-se dejeção de resíduos industriais no rio, afectando a população local há mais de uma semana.\",\n  \"occurrence_date\": \"2026-05-01\"\n}"
            },
