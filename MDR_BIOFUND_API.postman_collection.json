        },

        {
          "name": "📄 Listar todas as ocorrências",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/occurrences",
              "host": ["{{base_url}}"],
              "path": ["occurrences"]
            },
            "description": "Lista as ocorrências visíveis ao utilizador autenticado.\n\nVisibilidade por role:\n  Admin       → vê TODAS\n  Gestor      → vê da sua província + filtro de alertas\n  Funcionário → vê apenas as suas\n\nO campo alert_type aparece em cada ocorrência da lista."
          }
        },

        {
          "name": "🔍 Filtrar - alert_type: urgent",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/occurrences?alert_type=urgent",
              "host": ["{{base_url}}"],
              "path": ["occurrences"],
              "query": [
                { "key": "alert_type", "value": "urgent" }
              ]
            },
            "description": "Filtra apenas ocorrências urgentes.\n\n⚠️ Se estiver logado como Gestor Maputo (receives_urgent_alerts=false), o resultado será vazio mesmo que existam ocorrências urgentes - o filtro de visibilidade aplica-se primeiro."
          }
        },

        {
          "name": "🔍 Filtrar - alert_type: gbv",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/occurrences?alert_type=gbv",
              "host": ["{{base_url}}"],
              "path": ["occurrences"],
              "query": [
                { "key": "alert_type", "value": "gbv" }
              ]
            },
            "description": "Filtra apenas ocorrências GBV."
          }
        },

        {
          "name": "🔍 Filtrar - alert_type: normal",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/occurrences?alert_type=normal",
              "host": ["{{base_url}}"],
              "path": ["occurrences"],
              "query": [
                { "key": "alert_type", "value": "normal" }
              ]
            }
          }
        },

        {
          "name": "🔍 Filtrar - urgente + pendente",
