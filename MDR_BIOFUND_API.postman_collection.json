            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Retorna os dados do utilizador autenticado, incluindo receives_urgent_alerts e receives_gbv_alerts."
          }
