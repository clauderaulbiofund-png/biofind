          }
        },

        {
          "name": "Acompanhar ocorrência por código",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/public/occurrences/track/{{tracking_code}}",
              "host": ["{{base_url}}"],
              "path": ["public", "occurrences", "track", "{{tracking_code}}"]
