          }
        }

      ]
    },

    {
      "name": "🌐 Público (sem login)",
      "item": [

        {
          "name": "Dados do formulário (IDs de referência)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/public/form-data",
              "host": ["{{base_url}}"],
              "path": ["public", "form-data"]
            },
            "description": "Retorna todos os IDs de projetos, categorias, tipos e províncias.\nUsar estes IDs nos campos project_id, category_id, occurrence_type_id, province_id.\n\nTipos de ocorrência disponíveis:\n  id=1 Reclamação         [normal]\n  id=2 Consulta           [normal]\n  id=3 Sugestão           [normal]\n  id=4 Elogio             [normal]\n  id=5 Reclamação Urgente [urgent]\n  id=6 GBV                [gbv]"
          }
        },

        {
          "name": "Distritos de uma província",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/public/provinces/1/districts",
              "host": ["{{base_url}}"],
              "path": ["public", "provinces", "1", "districts"]
            },
            "description": "Trocar o '1' pelo ID da província pretendida."
          }
        },

        {
          "name": "Criar ocorrência externa (pública)",
          "event": [
            {
              "listen": "test",
              "script": {
