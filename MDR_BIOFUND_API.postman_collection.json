            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"Gaza@mdr.biofund.org.mz\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
